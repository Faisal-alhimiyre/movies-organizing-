# TheTVDB v4 credentials — copy this file to .env and fill in real values.
# The real .env file is git-ignored and must never be committed.
#
# Required:
TVDB_API_KEY=replace_locally
#
# Optional (subscriber PIN — only needed if your TheTVDB account
# requires a PIN to unlock extended data access; leave empty otherwise):
TVDB_PIN=
#
# TMDB — free key: https://www.themoviedb.org/settings/api
# Used by the tmdb-metadata edge function for per-episode ratings.
TMDB_API_KEY=replace_locally
